# KN Biosciences API Environment Configuration

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# JWT & AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ===========================================
# PAYMENT GATEWAY - EASEBUZZ
# ===========================================
EASEBUZZ_SALT=your-easebuzz-salt
EASEBUZZ_ENVIRONMENT=test
# Use 'production' for live environment

# ===========================================
# PAYMENT GATEWAY - PAYU (Alternative)
# ===========================================
PAYU_MERCHANT_KEY=your-payu-key
PAYU_MERCHANT_SALT=your-payu-salt
PAYU_ENVIRONMENT=test

# ===========================================
# SHIPPING - DELHIVERY
# ===========================================
DELHIVERY_API_KEY=your-delhivery-api-key
DELHIVERY_ENVIRONMENT=test

# ===========================================
# SHIPPING - VRL LOGISTICS
# ===========================================
VRL_API_KEY=your-vrl-api-key

# ===========================================
# ZOHO INTEGRATION
# ===========================================
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_ACCESS_TOKEN=your-zoho-access-token
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_ORGANIZATION_ID=your-zoho-org-id
ZOHO_REDIRECT_URI=https://api.knbiosciences.in/oauth/zoho/callback

# ===========================================
# NOTIFICATIONS - SENDGRID (Email)
# ===========================================
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@knbiosciences.in
FROM_NAME=KN Biosciences

# ===========================================
# NOTIFICATIONS - TWILIO (SMS & WhatsApp)
# ===========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGIN=https://www.knbiosciences.in,https://agriculture.knbiosciences.in,https://admin.knbiosciences.in
# Use '*' for development only

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=development
# Use 'production' for production

# ===========================================
# REDIS (Optional - for caching & rate limiting)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# FILE STORAGE (GCP Cloud Storage)
# ===========================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=your-bucket-name
GCP_KEY_FILE_PATH=./gcp-key.json

# ===========================================
# SENTRY (Error Tracking)
# ===========================================
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_TTL=60
# Time to live in seconds

RATE_LIMIT_MAX=100
# Maximum requests per TTL

# ===========================================
# FILE UPLOAD
# ===========================================
MAX_FILE_SIZE=10485760
# Maximum file size in bytes (10MB default)

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
# Comma-separated list of allowed MIME types
