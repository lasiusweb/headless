# KN Biosciences Web Frontend Environment Configuration

# ===========================================
# SUPABASE (Client-side)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# API CONFIGURATION
# ===========================================
NEXT_PUBLIC_API_URL=https://api.knbiosciences.in
# Use http://localhost:3000 for local development

# ===========================================
# PORTAL URLs
# ===========================================
NEXT_PUBLIC_B2B_URL=https://www.knbiosciences.in
# B2B Dealer Portal (localhost:3001 for development)

NEXT_PUBLIC_B2C_URL=https://agriculture.knbiosciences.in
# B2C Farmer Portal (localhost:3002 for development)

NEXT_PUBLIC_LANDING_URL=https://knbiosciences.in
# Landing Page (localhost:3000 for development)

# ===========================================
# COOKIE DOMAIN
# ===========================================
NEXT_PUBLIC_COOKIE_DOMAIN=.knbiosciences.in
# Use localhost for local development
# NEXT_PUBLIC_COOKIE_DOMAIN=localhost

# ===========================================
# FEATURE FLAGS
# ===========================================
NEXT_PUBLIC_ENABLE_LOYALTY=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_CHAT=false

# ===========================================
# ANALYTICS
# ===========================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Analytics Measurement ID

# ===========================================
# CDN (Optional)
# ===========================================
NEXT_PUBLIC_CDN_URL=https://cdn.knbiosciences.in
# For serving static assets
