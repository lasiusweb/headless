# KN Biosciences Landing Page Environment Configuration

# ===========================================
# API CONFIGURATION
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Use production URL in production: https://api.knbiosciences.in

# ===========================================
# PORTAL URLs
# ===========================================
NEXT_PUBLIC_B2B_URL=http://localhost:3001
# B2B Dealer Portal URL (www.knbiosciences.in)

NEXT_PUBLIC_B2C_URL=http://localhost:3002
# B2C Farmer Portal URL (agriculture.knbiosciences.in)

NEXT_PUBLIC_LANDING_URL=http://localhost:3000
# Landing Page URL (knbiosciences.in)

# ===========================================
# COOKIE DOMAIN
# ===========================================
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
# Use .knbiosciences.in for production
# Use localhost for local development

# ===========================================
# JWT SECRET (for token verification in middleware)
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
# Must match the JWT_SECRET in the API

# ===========================================
# SUPABASE (Client-side)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# ANALYTICS (Optional)
# ===========================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Analytics Measurement ID
